@startuml NoteP Project Schema

package "Entities" {
    class User {
        - id: long
        - name: String
        - surName: String
        - eMail: String
        - password: String
        - pages: List<Page>
        - groups: List<Group>
    }

    class Page {
        - id: long
        - title: String
        - content: String
        - createdDate: LocalDateTime
        - lastUpdateDate: LocalDateTime
        - user: User
        - group: Group
    }

    class Group {
        - id: long
        - name: String
        - password: String
        - members: List<User>
        - pages: List<Page>
    }
}

package "DataAccess" {
    interface UserRepository extends JpaRepository<User, Long> {
        + findByEMail(eMail: String): Optional<User>
        + existsByEMail(eMail: String): boolean
    }

    interface PageRepository extends JpaRepository<Page, Long> {
        + findByIdAndUserId(id: Long, userId: Long): Optional<Page>
        + findByUserId(userId: Long): List<Page>
        + findByGroupId(groupId: Long): List<Page>
        + findByUserIdAndGroupId(userId: Long, groupId: Long): List<Page>
    }

    interface GroupRepository extends JpaRepository<Group, Long> {
        + findByName(name: String): Optional<Group>
        + findByMembersId(userId: Long): List<Group>
    }
}

package "Bussiness" {
    class UserService {
        - userRepository: UserRepository
        - mapper: UserMapper
        - passwordEncoder: BCryptPasswordEncoder
        - jwtUtil: JWTUtil
        + register(userRequest: UserRequest)
        + logIn(loginRequest: LoginRequest): LoginResponse
        + getById(id: long): UserResponse
        + deleteById(id: long)
        + update(userRequest: UserRequest)
    }

    class PageService {
        - pageRepository: PageRepository
        - userRepository: UserRepository
        - userMapper: UserMapper
        - pageMapper: PageMapper
        + savePage(pageRequest: PageRequest)
        + getMyPages(): List<PageResponse>
        + updatePage(id: Long, pageResponse: PageResponse)
        + deleteById(id: Long)
    }

    class GroupService {
        - groupRepository: GroupRepository
        - pageRepository: PageRepository
        - userRepository: UserRepository
        - userMapper: UserMapper
        - pageMapper: PageMapper
        - groupMapper: GroupMapper
        - passwordEncoder: BCryptPasswordEncoder
        + createGroup(groupRequest: GroupRequest)
        + getMyGroups(): List<GroupResponse>
        + getGroupById(id: Long): GroupResponse
        + joinGroup(groupId: Long, joinRequest: JoinRequest)
        + deleteById(id: Long)
    }
}

package "DTOs" {
    class UserRequest {
        - name: String
        - surName: String
        - eMail: String
        - password: String
    }

    class UserResponse {
        - id: long
        - name: String
        - surName: String
        - eMail: String
    }

    class PageRequest {
        - title: String
        - content: String
    }

    class PageResponse {
        - id: long
        - title: String
        - content: String
        - groupId: Long
        - ownerId: Long
        - ownerName: String
    }

    class LoginRequest {
        - eMail: String
        - password: String
    }

    class LoginResponse {
        - token: String
        - message: String
        - user: UserResponse
    }

    interface IMapper<Response, Entity> {
        + toResponse(e: Entity): Response
    }

    class UserMapper implements IMapper<UserResponse, User> {
        + toResponse(u: User): UserResponse
        + toEntity(userRequest: UserRequest): User
        + updateEntityWithRequest(user: User, userRequest: UserRequest): User
    }

    class PageMapper implements IMapper<PageResponse, Page> {
        + toResponse(page: Page): PageResponse
        + toEntity(pageResponse: PageResponse): Page
        + updateEntityWithResponse(page: Page, pageResponse: PageResponse): Page
    }

    class GroupRequest {
        - name: String
        - password: String
    }

    class GroupResponse {
        - id: Long
        - name: String
        - members: List<User>
        - pages: List<Page>
    }

    class JoinRequest {
        - password: String
    }

    class GroupMapper implements IMapper<GroupResponse, Group> {
        + toResponse(group: Group): GroupResponse
        + toEntity(groupRequest: GroupRequest): Group
    }
}

package "Controllers" {
    class UserController {
        - userService: UserService
        + register(userRequest: UserRequest): ResponseEntity<Map<String, String>>
        + login(loginRequest: LoginRequest): ResponseEntity<String>
        + update(userRequest: UserRequest): ResponseEntity<Map<String, String>>
    }

    class PageController {
        - pageService: PageService
        + save(pageRequest: PageRequest): ResponseEntity<Map<String, String>>
        + getMyPages(): ResponseEntity<List<PageResponse>>
        + updatePage(id: Long, pageResponse: PageResponse): ResponseEntity<Map<String, String>>
        + delete(id: Long): ResponseEntity<Map<String, String>>
    }

    class GroupController {
        - groupService: GroupService
        + create(groupRequest: GroupRequest): ResponseEntity<Map<String, String>>
        + getMyGroups(): ResponseEntity<List<GroupResponse>>
        + getGroupById(id: Long): ResponseEntity<GroupResponse>
        + join(id: Long, joinRequest: JoinRequest): ResponseEntity<Map<String, String>>
    }
}

package "ExceptionHandling" {
    class GlobalExceptionHandler {
        + handleRuntimeException(ex: RuntimeException): ResponseEntity<Map<String, Object>>
        + handleIllegalArgumentException(ex: IllegalArgumentException): ResponseEntity<Map<String, Object>>
        + handleGeneralException(ex: Exception): ResponseEntity<Map<String, Object>>
    }
}

package "AuthenticationElements" {
    class JWTUtil {
        - secretKey: SecretKey
        + generateToken(eMail: String): String
        + extractEMail(token: String): String
        + validateToken(token: String, eMail: String): boolean
    }

    class JWTFilter {
        - jwtUtil: JWTUtil
        + doFilterInternal(request: HttpServletRequest, response: HttpServletResponse, filterChain: FilterChain)
    }

    class LoginRequest {
        - eMail: String
        - password: String
    }

    class LoginResponse {
        - token: String
        - message: String
        - user: UserResponse
    }
}

package "Config" {
    class SecurityConfig {
        + passwordEncoder(): BCryptPasswordEncoder
        + filterChain(http: HttpSecurity): SecurityFilterChain
    }
}

UserController --> UserService
UserService --> UserRepository
UserService --> UserMapper
UserService --> JWTUtil
UserService --> BCryptPasswordEncoder

PageController --> PageService
PageService --> PageRepository
PageService --> UserRepository
PageService --> UserMapper
PageService --> PageMapper

GroupController --> GroupService
GroupService --> GroupRepository
GroupService --> PageRepository
GroupService --> UserRepository
GroupService --> UserMapper
GroupService --> PageMapper
GroupService --> GroupMapper
GroupService --> BCryptPasswordEncoder

UserMapper --> UserResponse
UserMapper --> UserRequest
UserMapper --> User

PageMapper --> PageResponse
PageMapper --> Page

GroupMapper --> GroupResponse
GroupMapper --> GroupRequest
GroupMapper --> Group

User --> Page : has many
User --> Group : has many
Group --> Page : has many
Group --> User : has many

Page --> User : belongs to
Page --> Group : belongs to

GlobalExceptionHandler --> Controllers : advises

JWTFilter --> JWTUtil
SecurityConfig --> BCryptPasswordEncoder
SecurityConfig --> JWTFilter

@enduml
